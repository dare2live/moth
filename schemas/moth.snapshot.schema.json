{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/moth.snapshot.schema.json",
  "title": "Moth Snapshot",
  "type": "object",
  "required": ["status", "profile", "issues", "dirty_worktree"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["PASS", "WARN", "FAIL"]
    },
    "profile": {
      "type": "object"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dirty_worktree": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
